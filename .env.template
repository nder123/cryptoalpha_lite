# CryptoAlpha runtime environment template
# ─────────────────────────────────────────
# Copy to ~/.config/cryptoalpha/env (mode 0600) and fill in.
# Authoritative spec: docs/runtime_bootstrap_contract_v1.md §2.2
#
# bootstrap.sh will copy this file on first run if ~/.config/cryptoalpha/env
# does not yet exist. Required values must be set before any service starts.

# ── Operator authentication (REQUIRED) ──
# Shared secret between operator and backend. Used by:
#   - cryptoalpha-duty-check.service
#   - ops/rl_ops_summary.sh
#   - dashboard / system.py
OPERATOR_API_KEY=

# ── Exchange credentials (REQUIRED for LIVE / PAPER) ──
# Never commit. Never log. Rotate by editing this file then restarting backend.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Set to 1 to force testnet endpoints regardless of code defaults.
EXCHANGE_TESTNET=1

# ── Runtime mode (REQUIRED) ──
# One of: OFFLINE | SHADOW | PAPER | LIVE
# OFFLINE — no exchange contact at all
# SHADOW  — read-only observation, no orders
# PAPER   — simulated execution, real market data
# LIVE    — real orders against the exchange
RUNTIME_MODE=OFFLINE

# ── Storage & retention (optional, defaults shown) ──
# Backend mutable state directory.
RUNTIME_DATA_DIR=

# Retention quotas (Phase 1D worker reads these). Defaults: 4096 / 512.
RUNTIME_ARTIFACTS_QUOTA_MB=
RUNTIME_LOG_QUOTA_MB=

# Log verbosity.
RUNTIME_LOG_LEVEL=INFO
