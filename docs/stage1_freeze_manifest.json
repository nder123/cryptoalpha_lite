  ],
  "re_entry": {
    "errata_path": "Inline `## Errata` section under affected sub-doc; must preserve every invariant and axiom.",
    "amendment_path": "Bump affected sub-document to vN+1; update §1 of stage1_freeze_v1; tests grow.",
    "stage2_path": "New top-level freeze document docs/stage2_freeze_v1.md; co-exists with this freeze."
